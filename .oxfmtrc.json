{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  // oxfmt owns every format in the repo; bun.lock is excluded because bun
  // regenerates it and formatting would only create churn
  "ignorePatterns": ["bun.lock"],
  "proseWrap": "always",
  "semi": true,
  "trailingComma": "all",
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "sortImports": {
    "groups": [
      "side_effect",
      "test-libs",
      "builtin",
      "external",
      "unknown",
      ["parent", "sibling", "index"]
    ],
    "customGroups": [
      {
        "groupName": "test-libs",
        "elementNamePattern": ["bun:test"]
      }
    ],
    "newlinesBetween": false,
    "sortSideEffects": false
  }
}
