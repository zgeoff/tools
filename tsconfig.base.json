{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["bun"]
  },
  // inherited by every package (relative to this file) so the jest-extended
  // matcher augmentation is visible to per-package tsc
  "files": ["packages/bun-test-extended/src/augmentation.ts"]
}
