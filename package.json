{
  "name": "tools",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "typescript": "7.0.1-rc",
      "@types/bun": "1.3.14",
      "@tsconfig/strictest": "2.0.8",
      "@stylistic/eslint-plugin": "5.10.0",
      "oxfmt": "0.56.0",
      "oxlint": "1.71.0",
      "oxlint-tsgolint": "0.23.0"
    }
  },
  "type": "module",
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "build": "bun run --filter '*' build",
    "lint": "oxlint --report-unused-disable-directives-severity error",
    "lint:fix": "oxlint --fix",
    "lint:type-aware": "oxlint --type-aware --type-check --report-unused-disable-directives-severity error",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@tsconfig/strictest": "catalog:",
    "@types/bun": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  }
}
