{
  "name": "tools",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "typescript": "7.0.1-rc",
      "@types/bun": "1.3.14",
      "@tsconfig/strictest": "2.0.8",
      "@stylistic/eslint-plugin": "5.10.0",
      "oxfmt": "0.56.0",
      "oxlint": "1.71.0",
      "oxlint-tsgolint": "0.23.0",
      "prettier": "3.8.4"
    }
  },
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "build": "bun run --filter '*' build",
    "lint": "oxlint",
    "lint:type-aware": "oxlint --type-aware",
    "format": "bun run format:js && bun run format:rest",
    "format:check": "bun run format:js:check && bun run format:rest:check",
    "format:js": "oxfmt .",
    "format:js:check": "oxfmt --check .",
    "format:rest": "prettier --write . '!**/*.{js,jsx,ts,tsx,cjs,mjs}'",
    "format:rest:check": "prettier --check . '!**/*.{js,jsx,ts,tsx,cjs,mjs}'"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@tsconfig/strictest": "catalog:",
    "@types/bun": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
