{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "promise"],
  "jsPlugins": ["@zgeoff/oxlint-config/plugin", "@stylistic/eslint-plugin"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "pedantic": "error",
    "style": "error"
  },
  "env": {
    "node": true,
    "es2024": true
  },
  "rules": {
    // custom AST rules from plugin.js
    "zgeoff/no-top-level-arrow": "error",
    "zgeoff/no-nested-function-declaration": "error",
    "zgeoff/no-bare-named-exports": "error",
    "zgeoff/no-inline-param-object-types": "error",
    "zgeoff/no-destructured-params": "error",
    "zgeoff/no-pick-destructuring": "error",
    "zgeoff/no-ternary-args": "error",
    "zgeoff/no-await-args": "error",

    // enforced comment style — line comments unless JSDoc or exclamation
    "@stylistic/multiline-comment-style": [
      "error",
      "separate-lines",
      { "checkJSDoc": false, "checkExclamation": false }
    ],

    // own-line comments get a blank line above so they don't crowd the
    // previous statement; comments opening a block/object/class/etc are exempt
    "@stylistic/lines-around-comment": [
      "error",
      {
        "beforeLineComment": true,
        "beforeBlockComment": true,
        "allowBlockStart": true,
        "allowObjectStart": true,
        "allowArrayStart": true,
        "allowClassStart": true,
        "allowEnumStart": true,
        "allowInterfaceStart": true,
        "allowModuleStart": true,
        "allowTypeStart": true
      }
    ],

    // restriction-category cherry-picks
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "import/no-cycle": "error",

    "no-shadow": "error",

    // separate type-only imports from value imports
    "typescript/consistent-type-imports": [
      "error",
      { "prefer": "type-imports", "fixStyle": "separate-type-imports" }
    ],
    "no-duplicate-imports": ["error", { "allowSeparateTypeImports": true }],
    // oxfmt's sortImports owns import declaration order; lint only member order
    "sort-imports": ["error", { "ignoreDeclarationSort": true }],

    // allows destructuring for omitting properties
    "no-unused-vars": ["error", { "ignoreRestSiblings": true }],

    // arrays: destructure instead of indexing; objects: house style is direct
    // member access, so never required (the omit-via-rest exception lives in
    // zgeoff/no-pick-destructuring)
    "prefer-destructuring": [
      "error",
      {
        "VariableDeclarator": { "array": true, "object": false },
        "AssignmentExpression": { "array": false, "object": false }
      }
    ],

    // consistent function syntax — declarations top level, arrows for inside
    // blocks and callbacks
    "func-style": ["error", "declaration", { "allowArrowFunctions": true }],
    "no-inner-declarations": ["error", "functions"],
    "prefer-arrow-callback": ["error", { "allowNamedFunctions": false, "allowUnboundThis": false }],

    // stylistic
    "curly": ["error", "all"],
    "unicorn/prefer-ternary": ["error", "only-single-line"],
    "unicorn/prefer-node-protocol": "error",
    "unicorn/no-array-sort": "error",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-useless-undefined": ["error", { "checkArguments": false }],
    "unicorn/no-null": "off",
    "unicorn/number-literal-case": "off",
    "unicorn/filename-case": "off",

    // category-enabled rules that contradict this config's style: inline named
    // export declarations are the convention (group-exports demands the exact
    // form no-bare-named-exports bans), keys group by meaning not alphabet,
    // comments stay lowercase, short identifiers and literal numbers are fine
    "import/prefer-default-export": "off",
    "import/no-named-export": "off",
    "import/exports-last": "off",
    "import/group-exports": "off",
    "sort-keys": "off",
    "capitalized-comments": "off",
    "id-length": "off",
    "no-magic-numbers": "off",
    // prefer-ternary (only-single-line, above) wants ternaries where they fit
    // on one line; no-ternary would ban the same code
    "no-ternary": "off",
    // this config targets node/bun tooling — node builtins are the platform
    "import/no-nodejs-modules": "off",

    // preload-style modules (matcher registration, type augmentation) are
    // side-effect imports by design
    "import/no-unassigned-import": [
      "error",
      { "allow": ["jest-extended", "**/augment-bun-test.ts"] }
    ],

    // disable import rules that duplicate work TypeScript's compiler already
    // does
    "import/namespace": "off",
    "import/named": "off",
    "import/default": "off",
    "import/no-named-as-default-member": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      // one co-located suite per module with inline test data: file length
      // scales with coverage, not complexity
      "rules": {
        "max-lines": "off"
      }
    },
    {
      "files": ["**/*.js", "**/*.cjs", "**/*.mjs"],
      // untyped JS is `any` end to end, so the unsafe-* rules flag every
      // expression
      "rules": {
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-return": "off",
        "typescript/no-unsafe-type-assertion": "off"
      }
    }
  ]
}
