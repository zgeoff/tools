{
  "name": "@zgeoff/format-codemod",
  "version": "0.0.3",
  "description": "Enforce blank-line padding conventions in TypeScript via a fast text-splice codemod",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zgeoff/tools.git",
    "directory": "packages/format-codemod"
  },
  "bin": {
    "format-codemod": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/cli.ts --outdir dist --target node --packages external && tsc -p tsconfig.build.json",
    "prepare": "bun run build",
    "typecheck": "tsc"
  },
  "dependencies": {
    "oxc-parser": "0.137.0"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=22"
  }
}
