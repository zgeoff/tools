{
  "name": "@zgeoff/bun-test-extended",
  "version": "0.0.2",
  "description": "jest-extended matchers for bun test, with working failure messages and bun-aware types",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zgeoff/tools.git",
    "directory": "packages/bun-test-extended"
  },
  "files": [
    "src",
    "!src/*.test.ts",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "bun run build",
    "typecheck": "tsc"
  },
  "dependencies": {
    "jest-extended": "catalog:",
    "jest-matcher-utils": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.3"
  }
}
