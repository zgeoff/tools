{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  // the base config injects this package's augmentation source through "files"
  // for other packages' programs; declaration emit must cover these sources only
  "files": [],
  "include": ["src"],
  // co-located test files never ship; declaration emit skips them
  "exclude": ["src/**/*.test.ts"]
}
